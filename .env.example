# OPENAI_API_KEY from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# API_TOKEN for local testing
API_TOKEN=local-dev-token

# Server configuration
PORT=3000

# UV Project specific variables
UV_INVENTORY_API_KEY=
UV_SOURCE_LOC=
UV_VENUE_CODE=
UV_SOURCE_CODE=crossbook

# Fellowship API (optional — enables get_guest_context tool)
UV_SYSTEM_ID=
UV_FELLOWSHIP_SOURCE_CODE=public

# CORS configuration
ALLOWED_ORIGINS=https://example.com,https://www.example.com
